# Application Configuration
PORT=3000
ENV=development
APP_NAME=gofiber-skeleton
APP_VERSION=1.0.0

# Database Configuration
DATABASE_URL=postgres://gofiber:password@localhost:5432/gofiber_skeleton?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Configuration
CORS_ORIGINS=*

# Log Level (debug, info, warn, error)
LOG_LEVEL=info